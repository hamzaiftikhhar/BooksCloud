<% content_for :title, "Borrowing details" %>

<div class="d-flex justify-content-between align-items-start mb-4 gap-3 flex-column flex-md-row">
  <div>
    <h1 class="mb-1"><%= @borrowing.book.title %></h1>
    <p class="text-muted mb-0">Loan record for <%= @borrowing.member.name %>.</p>
  </div>
  <div class="d-flex gap-2 flex-wrap">
    <%= link_to "Back to borrowings", borrowings_path, class: "btn btn-outline-secondary" %>
    <% if @borrowing.active? %>

      <%= button_to "Record return", return_book_borrowing_path(@borrowing), method: :patch, class: "btn btn-primary" %>
    <% end %>
  </div>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Loan details</h5></div>
      <div class="card-body">
        <dl class="row">
          <dt class="col-5">Member</dt>
          <dd class="col-7"><%= link_to @borrowing.member.name, member_path(@borrowing.member) %></dd>

          <dt class="col-5">Status</dt>
          <dd class="col-7"><span class="badge bg-<%= @borrowing.active? ? "success" : "secondary" %>"><%= @borrowing.status.humanize %></span></dd>

          <dt class="col-5">Issued</dt>
          <dd class="col-7"><%= @borrowing.issue_date&.strftime("%b %d, %Y") %></dd>

          <dt class="col-5">Due date</dt>
          <dd class="col-7"><%= @borrowing.due_date&.strftime("%b %d, %Y") %></dd>

          <dt class="col-5">Returned</dt>
          <dd class="col-7"><%= @borrowing.return_date&.strftime("%b %d, %Y") || "Not returned" %></dd>

          <dt class="col-5">Overdue</dt>
          <dd class="col-7"><%= @borrowing.overdue? ? "Yes" : "No" %></dd>
        </dl>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card mb-4">
      <div class="card-header"><h5 class="mb-0">Book information</h5></div>
      <div class="card-body">
        <p class="mb-2"><strong>Title:</strong> <%= @borrowing.book.title %></p>
        <p class="mb-2"><strong>ISBN:</strong> <%= @borrowing.book.isbn %></p>
        <p class="mb-2"><strong>Genre:</strong> <%= @borrowing.book.genre.humanize %></p>
        <p class="mb-0"><strong>Copies available:</strong> <%= @borrowing.book.available_copy_count %></p>
      </div>
    </div>

    <% if @borrowing.fines.any? %>
      <div class="card">
        <div class="card-header"><h5 class="mb-0">Fine</h5></div>
        <div class="card-body">
          <% @borrowing.fines.each do |fine| %>
            <p class="mb-1"><strong>Status:</strong> <%= fine.status.humanize %></p>
            <p class="mb-1"><strong>Due:</strong> PKR <%= fine.amount_due %></p>
            <p class="mb-0"><strong>Paid:</strong> PKR <%= fine.amount_paid || 0 %></p>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
