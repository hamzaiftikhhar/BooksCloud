<% content_for :title, "Borrowings" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Borrowings</h1>
    <p class="text-muted mb-0">Browse all book loans and record returns.</p>
  </div>
</div>

<% if @borrowings.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Book</th>
          <th>Member</th>
          <th>Borrowing Status</th>
          <th>Due date</th>
          <th>Returned</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @borrowings.each do |borrowing| %>
          <tr>
            <td><%= link_to borrowing.book.title, borrowing_path(borrowing), class: "text-decoration-none" %></td>
            <td><%= link_to borrowing.member.name, member_path(borrowing.member), class: "text-decoration-none" %></td>
            <td><span class="badge justify-content-center align-items-center bg-<%= borrowing.active? ? "success" : "secondary" %>"><%= borrowing.status.humanize %></span></td>
            <td><%= borrowing.due_date&.strftime("%b %d, %Y") %></td>
            <td><%= borrowing.return_date&.strftime("%b %d, %Y") || "—" %></td>
            <td><%= link_to "View", borrowing_path(borrowing), class: "btn btn-outline-primary btn-sm" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No borrowings have been recorded yet.</p>
<% end %>
