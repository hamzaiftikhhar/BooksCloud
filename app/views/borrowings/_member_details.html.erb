<%= turbo_frame_tag "member_check" do%>

  <div class="card shadow-sm border-0">
    <div class="card-body">

      <% if member %>

        <div class="d-flex justify-content-between align-items-start mb-3">
          <div>
            <h5 class="fw-bold mb-1">Member Verification</h5>

            <p class="text-muted small mb-1">
              ID: <%= member.membership_number %>
            </p>

            <h6 class="mb-0 fw-semibold">
              <%= member.name %>
            </h6>
          </div>

          <% if member.suspended? %>
            <span class="badge bg-danger rounded-pill">
              Suspended
            </span>

          <% elsif member.expired? %>
            <span class="badge bg-warning text-dark rounded-pill">
              Expired
            </span>

          <% else %>
            <span class="badge bg-success rounded-pill">
              Active
            </span>
          <% end %>
        </div>

        <div class="row g-3 mb-3">

          <div class="col-6">
            <div class="bg-light rounded p-3 text-center h-100">
              <small class="text-muted d-block">
                Current Loans
              </small>

              <div class="fw-bold fs-5">
                <%= member.active_borrowings.count %> /
                <%= member.max_books_allowed %>
              </div>
            </div>
          </div>

          <div class="col-6">
            <div class="bg-light rounded p-3 text-center h-100">
              <small class="text-muted d-block">
                Overdue Fines
              </small>

              <div class="fw-bold fs-5">
                PKR <%= number_with_precision(member.fines.outstanding.sum(:amount_due), precision: 2) %>
              </div>
            </div>
          </div>

        </div>

        <div class="alert alert-secondary py-2 mb-3">
          Issuing:
          <strong><%= book.title %></strong>
        </div>

        <% if !member.suspended? &&
              !member.expired? &&
              member.active_borrowings.count < member.max_books_allowed %>

          <%= button_to borrowings_path(
                book_id: book.id,
                borrowing: {
                membership_number: member.membership_number
                }
              ),
              method: :post,
               form: { data: { turbo: false } },
              class: "btn btn-primary w-100" do %>

            Confirm & Issue

          <% end %>

        <% else %>

          <button class="btn btn-secondary w-100" disabled>
            Ineligible to Borrow
          </button>

        <% end %>

      <% else %>

        <div class="text-center py-4">
          <h5 class="text-danger mb-2">
            Member Not Found
          </h5>

          <p class="text-muted mb-0">
            No member matches that membership number.
          </p>
        </div>

      <% end %>

    </div>
  </div>

<% end %>