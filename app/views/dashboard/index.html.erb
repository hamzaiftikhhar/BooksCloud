<% content_for :title, "Dashboard" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h3 class="mb-2">Dashboard</h3>
    <h2 style="color: purple;">Hello <%= current_user.email %></h2>
    <date style="color: gray;"><%= Time.current.strftime("%B %d, %Y") %></date>
    <p class="text-muted mb-0 mt-5">Library overview and quick actions.</p>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card text-white bg-primary h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <h5 class="card-title">Total Books</h5>
        <p class="card-text display-4"><%= @books_count %></p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-success h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <h5 class="card-title">Total Members</h5>
        <p class="card-text display-4"><%= @members_count %></p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-warning h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <h5 class="card-title">Active Borrowings</h5>
        <p class="card-text display-4"><%= @active_borrowings_count %></p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-danger h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <h5 class="card-title">Overdue Books</h5>
        <p class="card-text display-4"><%= @overdue_borrowings_count %></p>
      </div>
    </div>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Recently Added Books</h5>
      </div>
      <div class="card-body">
        <% if @recent_books.any? %>
          <ul class="list-group list-group-flush">
            <% @recent_books.each do |book| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <%= link_to book.title, book_path(book), class: "text-decoration-none" %>
                <span class="badge bg-secondary"><%= book.created_at.strftime("%b %d, %Y") %></span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No books have been added yet.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Top Borrowed Books</h5>
      </div>
      <div class="card-body">
        <% if @top_borrowed_books.any? %>
          <ul class="list-group list-group-flush">
            <% @top_borrowed_books.each do |book| %>
              <li class="list-group-item d-flex justify-content-between align-items-center">
                <%= link_to book.title, book_path(book), class: "text-decoration-none" %>
                <span class="badge bg-secondary"><%= book.borrow_count %> borrows</span>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No books have been borrowed yet.</p>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="row g-4">
  <div class="col-lg-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Recent Borrowings</h5>
      </div>
      <div class="card-body">
        <% if @recent_borrowings.any? %>
          <ul class="list-group list-group-flush">
            <% @recent_borrowings.each do |borrowing| %>
              <li class="list-group-item">
                <div class="d-flex justify-content-between align-items-start gap-3">
                  <div>
                    <h6 class="mb-1"><%= link_to borrowing.book.title, borrowing_path(borrowing), class: "text-decoration-none" %></h6>
                    <p class="mb-1 text-muted">by <%= borrowing.member.name %></p>
                  </div>
                  <span class="badge bg-<%= borrowing.active? ? "success" : "secondary" %>"><%= borrowing.status.humanize %></span>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="text-muted mb-0">No borrowings have been recorded yet.</p>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-lg-6">
    <div class="card">
      <div class="card-header">
        <h5 class="mb-0">Quick Actions</h5>
      </div>
      <div class="card-body">
        <div class="d-grid gap-2">
          <%= link_to "Add New Book", new_book_path, class: "btn btn-outline-primary" %>
          <%= link_to "Register Member", new_member_path, class: "btn btn-outline-success" %>
          <%= link_to "View All Borrowings", borrowings_path, class: "btn btn-outline-warning" %>
          <%= link_to "View Reports", reports_root_path, class: "btn btn-outline-info" %>
          <% if current_user&.admin? %>
            <%= link_to "Admin Panel", admin_root_path, class: "btn btn-outline-danger" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
