<%# what should be here 
This is the dashboard page where users can see an overview of the products. It includes a search bar to filter products and a list of products with options to view details.
The content_for :title is used to set the page title dynamically. In this case, it sets the title to "Books". This allows the layout to display the appropriate title for this page.%>

<% content_for :title, "Books" %> 

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Books</h1>
    <p class="text-muted mb-0">Browse all available books and manage them from one place.</p>
  </div>
  <% if policy(Book).create? %>
    <%= link_to "New Book", new_book_path, class: "btn btn-outline-dark" %>
  <% end %>
</div>

<%= form_with url: books_path, method: :get, data: { controller: "search", turbo_frame: "books" } do %>
  <%= text_field_tag :query,
        params[:query],
        placeholder: "Search books...",
        class: "form-control mb-4 border-1 rounded-4 input-group-lg",
        data: { action: "input->search#debounce" } %>

<% end %>
<div class="row g-4 mb-4">
  <div class="col-md-3">
    <div class="card text-white bg-primary h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <h5 class="card-title">Total Books</h5>
        <p class="card-text display-4"><%= @books_count %></p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-success h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <h5 class="card-title">Total Members</h5>
        <p class="card-text display-4"><%= @members_count %></p>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-white bg-warning h-100">
      <div class="card-body d-flex flex-column justify-content-center align-items-center">
        <h5 class="card-title">Active Borrowings</h5>
        <p class="card-text display-4"><%= @active_borrowings_count %></p>
      </div>
    </div>
  </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger h-100">
        <div class="card-body d-flex flex-column justify-content-center align-items-center">
            <h5 class="card-title">Overdue Books</h5>
            <p class="card-text display-4"><%= @overdue_borrowings_count %></p>
        </div>
        </div>
    </div>

  <!-- Add more cards as needed -->
</div>
<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">Recently Added Books</h5>
  </div>
  <div class="card-body">
    <% if @books.any? %>
      <ul class="list-group list-group-flush">
        <% @books.order(created_at: :desc).limit(5).each do |book| %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <%= link_to book.title, book_path(book), class: "text-decoration-none" %>
            <span class="badge bg-secondary"><%= book.created_at.strftime("%b %d, %Y") %></span>
          </li>
        <% end %>
      </ul>
    <% else %>      <p class="text-muted mb-0">No books have been added yet.</p>
    <% end %>
  </div>
</div>  

<div class="card mb-4">
  <div class="card-header">
    <h5 class="mb-0">Top Borrowed Books</h5>
  </div>
  <div class="card-body">
    <% if @books.any? %>
      <ul class="list-group list-group-flush">
        <% @books.left_joins(:borrowings).group(:id).order('COUNT(borrowings.id) DESC').limit(5).each do |book| %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <%= link_to book.title, book_path(book), class: "text-decoration-none" %>
            <span class="badge bg-secondary"><%= book.borrowings.count %> borrows</span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="text-muted mb-0">No books have been borrowed yet.</p    >
    <% end %>
  </div>
</div>      


<div class="row">
    <h2 class="mb-4">All Books</h2>
  <% @books.each do |book| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= link_to book.title, book_path(book), class: "text-decoration-none" %></h5>
          <p class="card-text"><%= truncate(book.description.to_plain_text, length: 100) %></p>
          <div class="mt-auto">
            <%= link_to "View Details", book_path(book), class: "btn btn-outline-primary btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>