<%= form_with url: search_books_path, method: :get, local: true, class: "mb-4" do |form| %>
  <div class="input-group gap-2 flex-wrap ">

    
    <%= form.text_field :q, value: params[:q], placeholder: "Search by title or author", class: "form-control" %>
    <%= form.select :genre, options_for_select(Book.distinct.pluck(:genre).compact, params[:genre]), include_blank: "All Genres", class: "form-select" %>
    <%= form.select :availability, options_for_select([["All", ""], ["Available", "available"], ["Checked Out", "checked_out"]], params[:availability]), class: "form-select" %>
    <button type="submit" class: "btn btn-primary">Search</button>
      <button type="button" class: "btn btn-secondary" id="clear-search">Clear</button>
  </div>
<% end %>
<div class="row">
  <% @books.each do |book| %>
    <div class="col-md-4 mb-4">
      <div class="card h-100">
        <div class="card-body d-flex flex-column">
          <h5 class="card-title"><%= link_to book.title, book_path(book), class: "text-decoration-none" %></h5>
          <p class="card-text"><%= truncate(book.description.to_plain_text, length: 100) %></p>
          <div class="mt-auto">
            <%= link_to "View Details", book_path(book), class: "btn btn-outline-primary btn-sm" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>