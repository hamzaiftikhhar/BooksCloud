<%= form_with url: search_books_path, method: :get, local: true, class: "mb-4" do |form| %>
  <div class="row g-3 align-items-end">
    <div class="col-md-4">
      <%= form.label :q, "Search" %>
      <%= form.text_field :q, value: params[:q], placeholder: "Search by title, author or ISBN", class: "form-control" %>
    </div>
    <div class="col-md-3">
      <%= form.label :genre, "Genre" %>
      <%= form.select :genre, options_for_select(Book.genres.keys.map { |genre| [genre.humanize, genre] }, params[:genre]), { include_blank: "All genres" }, class: "form-select" %>
    </div>
    <div class="col-md-3">
      <%= form.label :availability, "Availability" %>
      <%= form.select :availability, options_for_select([["All", ""], ["Available", "available"], ["Unavailable", "unavailable"]], params[:availability]), {}, class: "form-select" %>
    </div>
    <div class="col-md-2 d-grid">
      <%= form.submit "Search", class: "btn btn-primary" %>
    </div>
  </div>
<% end %>



<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
  <% @books.each do |book| %>
    <div class="col">
      <div class="card h-100 img-card border-0 shadow-sm custom-card">
        <% if book.cover.attached? %> 
          <div class="p-3"> 
            <%= link_to book_path(book) do %>
              <%= image_tag book.cover, class: "img-fluid book-cover-img" %>
            <% end %>
          </div>
        <% end %> 
        <div class="card-body d-flex flex-column pt-0">
          <h5 class="card-title font-weight-bold mb-1">
            <%= link_to book.title, book_path(book), class: "text-dark text-decoration-none" %>
          </h5>
          <p class="text-muted small mb-3"><%= truncate(book.description, length: 80) %></p>
          <div class="mt-auto d-flex justify-content-between align-items-center">
            <span class="badge rounded-pill bg-light text-dark border">
              Available: <%= book.available_copy_count %>
            </span>
            <%= link_to "View", book_path(book), class: "btn btn-primary btn-sm rounded-pill px-3" %>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>



<div class="mt-4 pagination">
  <%= paginate @books if @books.respond_to?(:total_pages) %>
</div>

