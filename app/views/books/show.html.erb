<div class="container">
  <div class="row mb-4">
    <div class="col-12 d-flex justify-content-between align-items-center flex-column flex-md-row gap-3">
      <div>
        <h1 class="mb-1"><%= @book.title %></h1>
        <p class="text-muted mb-0">Book details, availability, and issue actions.</p>
      </div>
      <div class="d-flex gap-2 flex-wrap">
        <%= link_to "Back to Books", books_path, class: "btn btn-outline-secondary" %>
        <%= link_to "Edit Book", edit_book_path(@book), class: "btn btn-primary" %>
        <% if current_user&.admin? %>
          <%= button_to "Delete Book", @book, method: :delete, class: "btn btn-danger" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-8 ">
      <div class="card h-100 img-card border-0 shadow-sm custom-card">
        <div class="card-body">
          <% if @book.cover.attached? %>
            <div class="text-center mb-3">
              <%= image_tag @book.cover, class: "img-fluid rounded" %>
            </div>
          <% end %>

          <h2 class="h4"><%= @book.title %></h2>
          <p class="text-muted">by <%= @book.author.name %></p>
          <p class="mb-3"><%= simple_format(@book.description.to_plain_text) %></p>

          <dl class="row mb-0">
            <dt class="col-sm-4">Genre</dt>
            <dd class="col-sm-8"><%= @book.genre.humanize %></dd>

            <dt class="col-sm-4">ISBN</dt>
            <dd class="col-sm-8"><%= @book.isbn %></dd>

            <dt class="col-sm-4">Publication date</dt>
            <dd class="col-sm-8"><%= @book.publication_date.strftime("%B %d, %Y") %></dd>
          </dl>

          <%= render "inventory", book: @book %>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card mb-4">
        <div class="card-header"><h5 class="mb-0">Issue this book</h5></div>
        <div class="card-body">
          <%= form_with url: search_member_borrowings_path, method: :get, data: { turbo_frame: "member_check" } do |f| %>

            <%= hidden_field_tag :book_id, @book.id %>
            <div class="mb-3">
              <%# data: { turbo_frame: "member_check" } this line is passing the data to the member_check form  %>
              <%= f.label :membership_number, "Search Member by ID" %>

              <%= f.text_field :membership_number, placeholder: "Enter membership number", class: "form-control" %>
            </div>
            
            <%= f.submit "Search & Verify Member", class: "btn btn-outline-primary w-100" %>
          <% end %>
        </div>
      </div>

      <%= turbo_frame_tag "member_check" do %>
      <% end %>



      <div class="card">
        <div class="card-header"><h5 class="mb-0">Quick info</h5></div>
        <div class="card-body">
          <p class="mb-2"><strong>Available copies:</strong> <%= @book.available_copy_count %></p>
          <p class="mb-2"><strong>Total copies:</strong> <%= @book.total_copy_count %></p>
          <p class="mb-0"><strong>Borrowed count:</strong> <%= @book.borrowings.count %></p>
        </div>
      </div>
    </div>
  </div>
</div>

