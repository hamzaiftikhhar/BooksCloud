<div class="container mt-4">
  <h1 class="mb-4">Search Results</h1>
  
  <div class="row">
    <% if @books.present? %>
      <% @books.each do |book| %>
        <div class="col-md-4 mb-4">
          <div class="card h-100">
            <div class="card-body d-flex flex-column">
              <h5 class="card-title"><%= link_to book.title, book_path(book), class: "text-decoration-none" %></h5>
              <p class="card-text"><%= book.description %></p>
              <div class="mt-auto">
                <%= button_to "Feature", feature_book_path(book), method: :patch, class: "btn btn-outline-primary btn-sm" %>
              </div>
            </div>
          </div>
        </div>
      <% end %> 
    <% end %> 

    <% if @books.blank? %>
      <div class="col-12">
        <p class="text-muted">No books found matching your search criteria.</p>
        <%= link_to "Back to Books", books_path, class: "btn btn-secondary" %>
      </div>
    <% end %>
  </div>
</div>
