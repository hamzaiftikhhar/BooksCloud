<%= form_with model: @book do |form| %>

  <h4 class="mb-4">Add New Book</h4>

  <% if form.object.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% form.object.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :title %>
      <%= form.text_field :title, class: "form-control" %>
    </div>

    <div class="col-md-6 mb-3">
      <%= form.label :isbn %>
      <%= form.text_field :isbn, class: "form-control" %>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 4, class: "form-control" %>
  </div>

<div class="mb-3">
  <%= form.label :genre, class: "form-label" %>

     <%= form.select :genre,
      Book.genres.keys.map { |g| [g.humanize, g] },
      { prompt: "Select Genre" },
      class: "form-select select2" %>   
</div>

  <div class="mb-3">
    <%= form.label :author_id, "Author" %>
    <%= form.collection_select :author_id, Author.all, :id, :first_name,
        { prompt: "Select an author" },
        class: "form-select" %>
  </div>
  <div class="mb-3">
    <%= form.label :publication_date %>
    <%= form.date_field :publication_date, class: "form-control" %>
  </div>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :total_copy_count %>
      <%= form.number_field :total_copy_count, class: "form-control" %>
    </div>

    <div class="col-md-6 mb-3">
      <%= form.label :available_copy_count %>
      <%= form.number_field :available_copy_count, class: "form-control" %>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :cover %>
    <%= form.file_field :cover, class: "form-control" %>
  </div>

  <div class="d-grid">
    <%= form.submit "Save Book", class: "btn btn-primary btn-lg" %>
  </div>

<% end %>