<%= form_with model: @book, data: { turbo: false } do |form| %>

  <h4 class="mb-4">Add New Book</h4>

  <% if form.object.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% form.object.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :title %>
      <%= form.text_field :title, class: "form-control" %>
    </div>

    <div class="col-md-6 mb-3">
  <div class="d-flex align-items-center mb-1">
    <%= form.label :isbn, class: "mb-0 mr-2" %>
    <button type="button" class="btn btn-link p-0 text-decoration-none" 
            data-bs-toggle="tooltip" data-bs-placement="top" 
            title="Enter the 10 or 13-digit number found on the book's back cover or copyright page. (e.g., 9783161484100 or 0306406152)">
      <i class="bi bi-info-circle"> i</i>
    </button>
  </div>
  <%= form.text_field :isbn, class: "form-control", placeholder: "Enter ISBN 13 or 10 digits" %>
</div>

  </div>

  <div class="mb-3">
    <%= form.label :description %>
    <%= form.text_area :description, rows: 4, class: "form-control" %>
  </div>


<div class="mb-3">
  <%= form.label :genre, class: "form-label" %>

     <%= form.select :genre,
      Book.genres.keys.map { |g| [g.humanize, g] },
      { prompt: "Select Genre" },
      class: "form-select select2" %>   
</div>

<div id="author-search-container">
  <div class="mb-3">
    <label for="book_author_name">Author Name</label>
    <div class="position-relative">
      <input class="form-control" 
             placeholder="e.g. J.R.R. Tolkien" 
             autocomplete="off" 
             type="text" 
             name="book[author_name]" 
             id="book_author_name" />
      
      <div id="author-suggestions" class="position-absolute w-100 mt-1 bg-white border rounded shadow-sm"
           style="display: none; max-height: 300px; overflow-y: auto; z-index: 1000;">
      </div>
    </div>
    <small class="text-muted">Start typing to search authors or create a new one.</small>
  </div>
  <input id="selected_author_id" type="hidden" name="book[author_id]" />
</div>

<script>
  (function() {
    const input = document.getElementById('book_author_name');
    const suggestionsBox = document.getElementById('author-suggestions');
    const authorIdInput = document.getElementById('selected_author_id');
    
    let debounceTimer = null;
    const debounceDelay = 250;
    
    input.addEventListener('input', function(event) {
      clearTimeout(debounceTimer);
      
      const query = input.value.trim();
      console.log(`Author search triggered: "${query}"`);
      
      if (query.length < 2) {
        suggestionsBox.style.display = 'none';
        return;
      }
      
      debounceTimer = setTimeout(() => {
        fetchAuthors(query);
      }, debounceDelay);
    });
    
    function fetchAuthors(query) {
      const url = `/books/search_authors?q=${encodeURIComponent(query)}`;
      console.log(`Fetching authors from: ${url}`);
      
      fetch(url, {
        headers: { Accept: 'application/json' }
      })
        .then(r => {
          console.log(`Response status: ${r.status}`);
          return r.json();
        })
        .then(data => {
          console.log(`Authors data:`, data);
          renderSuggestions(data);
        })
        .catch(err => {
          console.error('Fetch error:', err);
          suggestionsBox.style.display = 'none';
        });
    }
    
    function renderSuggestions(authors) {
      suggestionsBox.innerHTML = '';
      
      if (!authors || !authors.length) {
        console.log('No authors found');
        suggestionsBox.style.display = 'none';
        return;
      }
      
      console.log(`Rendering ${authors.length} suggestions`);
      
      authors.forEach(author => {
        const div = document.createElement('div');
        div.textContent = author.name;
        div.style.cursor = 'pointer';
        div.style.padding = '8px 12px';
        div.style.borderBottom = '1px solid #ddd';
        
        div.onmouseover = () => { div.style.backgroundColor = '#f5f5f5'; };
        div.onmouseout = () => { div.style.backgroundColor = 'transparent'; };
        
        div.onclick = () => {
          console.log(`Selected author: ${author.name} (ID: ${author.id})`);
          input.value = author.name;
          authorIdInput.value = author.id;
          suggestionsBox.style.display = 'none';
        };
        
        suggestionsBox.appendChild(div);
      });
      
      suggestionsBox.style.display = 'block';
    }
  })();
</script>
  <div class="mb-3">
    <%= form.label :publication_date %>
    <%= form.date_field :publication_date, class: "form-control" %>
  </div>
  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :total_copy_count %>
      <%= form.number_field :total_copy_count, class: "form-control" %>
    </div>

    <div class="col-md-6 mb-3">
      <%= form.label :available_copy_count %>
      <%= form.number_field :available_copy_count, class: "form-control" %>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :cover %>
    <%= form.file_field :cover, class: "form-control" %>
  </div>

  <div class="d-grid">
    <%= form.submit "Save Book", class: "btn btn-primary btn-lg" %>
  </div>

<% end %>