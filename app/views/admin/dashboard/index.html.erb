<% content_for :title, "Admin Dashboard" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Admin Dashboard</h1>
    <p class="text-muted mb-0">Manage staff and review application activity.</p>
  </div>
</div>

<div class="row g-4 mb-4">
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title">Total staff</h5>
        <p class="display-5 mb-0"><%= @users.count %></p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title">Active members</h5>
        <p class="display-5 mb-0"><%= Member.active.count %></p>
      </div>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-body">
        <h5 class="card-title">Active borrowings</h5>
        <p class="display-5 mb-0"><%= Borrowing.active.count %></p>
      </div>
    </div>
  </div>
</div>

<div class="card">
  <div class="card-header"><h5 class="mb-0">Staff accounts</h5></div>
  <div class="card-body">
    <%= link_to "Manage staff", admin_users_path, class: "btn btn-primary" %>
  </div>
</div>
