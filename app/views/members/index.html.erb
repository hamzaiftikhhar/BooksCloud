<% content_for :title, "Members" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Members</h1>
    <p class="text-muted mb-0">Manage library members and quickly check borrowing status.</p>
  </div>
  <%= link_to "New Member", new_member_path, class: "btn btn-outline-dark" %>
</div>

<div class="row row-cols-1 row-cols-md-2 g-4">
  <% @members.each do |member| %>
    <div class="col">
      <div class="card h-100">
        <div class="card-body">
          <h5 class="card-title mb-1"><%= link_to member.name, member_path(member), class: "text-decoration-none" %></h5>
          <p class="mb-1"><strong>Membership:</strong> <%= member.membership_number %></p>
          <p class="mb-1"><strong>Status:</strong> <span class="badge bg-<%= member.active? ? "success" : member.suspended? ? "warning" : "secondary" %>"><%= member.status.humanize %></span></p>
          <p class="mb-0"><strong>Borrowed:</strong> <%= member.active_borrowings.count %> / <%= member.max_books_allowed %></p>
        </div>
        <div class="card-footer d-flex justify-content-between align-items-center">
          <%= link_to "View", member_path(member), class: "btn btn-outline-primary btn-sm" %>
          <%= link_to "Edit", edit_member_path(member), class: "btn btn-outline-secondary btn-sm" %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="mt-4">
  <%= paginate @members if @members.respond_to?(:total_pages) %>
</div>
