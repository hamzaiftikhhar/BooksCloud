<%= form_with model: @member, local: true do |form| %>
  <% if @member.errors.any? %>
    <div class="alert alert-danger">
      <p><strong>Please fix the following problems:</strong></p>
      <ul class="mb-0">
        <% @member.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :name %>
      <%= form.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :email %>
      <%= form.email_field :email, class: "form-control" %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :phone %>
      <%= form.telephone_field :phone, class: "form-control" %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :membership_number %>
      <%= form.text_field :membership_number, class: "form-control", readonly: true, disabled: true, value: @member.membership_number %>
    </div>
  </div>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :max_books_allowed, "Borrow limit" %>
      <%= form.number_field :max_books_allowed, class: "form-control", min: 1 %>
    </div>
    <div class="col-md-6 mb-3">
      <%= form.label :status %>
      <%= form.select :status, Member.statuses.keys.map { |status| [status.humanize, status] }, {}, class: "form-select" %>
    </div>
  </div>

  <div class="d-grid mt-3">
    <%= form.submit @member.new_record? ? "Create Member" : "Update Member", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>
