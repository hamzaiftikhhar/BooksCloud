<% content_for :title, "Monthly Borrowing" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Monthly Borrowing</h1>
    <p class="text-muted mb-0">Borrowing counts by month for the current year.</p>
  </div>
  <%= link_to "Back to reports", reports_root_path, class: "btn btn-outline-secondary" %>
</div>

<% data = @presenter.monthly_borrowing_data %>
<% if data.present? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Month</th>
          <th>Borrowings</th>
        </tr>
      </thead>
      <tbody>
        <% data.each do |month, count| %>
          <tr>
            <td><%= month %></td>
            <td><%= count %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No borrowing activity has been recorded for this year yet.</p>
<% end %>
