<% content_for :title, "Most Borrowed Books" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Most Borrowed Books</h1>
    <p class="text-muted mb-0">The ten books with the highest borrow count.</p>
  </div>
  <%= link_to "Back to reports", reports_root_path, class: "btn btn-outline-secondary" %>
</div>

<% if @presenter.most_borrowed_books.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Title</th>
          <th>Author</th>
          <th>ISBN</th>
          <th>Borrow count</th>
        </tr>
      </thead>
      <tbody>
        <% @presenter.most_borrowed_books.each do |book| %>
          <tr>
            <td><%= book[:title] %></td>
            <td><%= book[:author] %></td>
            <td><%= book[:isbn] %></td>
            <td><%= book[:borrow_count] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No borrowed books are available yet.</p>
<% end %>
