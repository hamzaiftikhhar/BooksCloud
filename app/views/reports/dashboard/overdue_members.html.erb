<% content_for :title, "Overdue Members" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Overdue Members</h1>
    <p class="text-muted mb-0">Members who currently have overdue borrowings.</p>
  </div>
  <%= link_to "Back to reports", reports_root_path, class: "btn btn-outline-secondary" %>
</div>

<% if @presenter.overdue_members.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Membership #</th>
          <th>Overdue loans</th>
        </tr>
      </thead>
      <tbody>
        <% @presenter.overdue_members.each do |member| %>
          <tr>
            <td><%= member[:name] %></td>
            <td><%= member[:email] %></td>
            <td><%= member[:membership_number] %></td>
            <td><%= member[:overdue_count] %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">There are no members with overdue borrowings at this time.</p>
<% end %>
