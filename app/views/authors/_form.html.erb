<%= form_with model: @author, local: true do |form| %>
  <% if @author.errors.any? %>
    <div class="alert alert-danger">
      <h4><%= pluralize(@author.errors.count, "error") %> prohibited this author from being saved:</h4>
      <ul class="mb-0">
        <% @author.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row">
    <div class="col-md-6 mb-3">
      <%= form.label :first_name %>
      <%= form.text_field :first_name, class: "form-control", placeholder: "e.g., J.R.R." %>
    </div>

    <div class="col-md-6 mb-3">
      <%= form.label :last_name %>
      <%= form.text_field :last_name, class: "form-control", placeholder: "e.g., Tolkien" %>
    </div>
  </div>

  <div class="d-grid">
    <%= form.submit class: "btn btn-primary btn-lg" %>
  </div>
<% end %>
