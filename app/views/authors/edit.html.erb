<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header">
          <h1 class="card-title mb-0">Edit Author</h1>
        </div>
        <div class="card-body">
          <%= render "form", author: @author %>
        </div>
        <div class="card-footer">
          <%= link_to "Cancel", @author, class: "btn btn-secondary" %>
        </div>
      </div>
    </div>
  </div>
</div>
