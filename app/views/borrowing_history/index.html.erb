<% content_for :title, "Borrowing History" %>

<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h1 class="mb-0">Borrowing history</h1>
    <p class="text-muted mb-0">Full borrowing record for <%= @member.name %>.</p>
  </div>
  <%= link_to "Back to member", member_path(@member), class: "btn btn-outline-secondary" %>
</div>

<% if @borrowings.any? %>
  <div class="table-responsive">
    <table class="table table-hover align-middle">
      <thead>
        <tr>
          <th>Book</th>
          <th>Status</th>
          <th>Issued</th>
          <th>Due</th>
          <th>Returned</th>
          <th>Overdue</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @borrowings.each do |borrowing| %>
          <tr>
            <td><%= link_to borrowing.book.title, borrowing_path(borrowing), class: "text-decoration-none" %></td>
            <td><span class="badge bg-<%= borrowing.active? ? "success" : "secondary" %>"><%= borrowing.status.humanize %></span></td>
            <td><%= borrowing.issue_date&.strftime("%b %d, %Y") %></td>
            <td><%= borrowing.due_date&.strftime("%b %d, %Y") %></td>
            <td><%= borrowing.return_date&.strftime("%b %d, %Y") || "—" %></td>
            <td><%= borrowing.overdue? ? "Yes" : "No" %></td>
            <td><%= link_to "Details", borrowing_path(borrowing), class: "btn btn-outline-primary btn-sm" %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <p class="text-muted">No borrowing history is available for this member.</p>
<% end %>
